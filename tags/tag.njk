---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /tags/{{ tag | slugify }}/
layout: base.njk
---
<div class="tag-page">
  <header class="tag-header">
    <a href="/tags/" class="back-link">← All tags</a>
    <h1>Posts tagged <span class="tag">{{ tag }}</span></h1>
  </header>

  <section class="posts-list">
    {% set taggedPosts = collections[tag] | reverse %}
    {% for post in taggedPosts %}
      <article class="post-card">
        <div class="post-card-meta">
          <time datetime="{{ post.date | dateToISO }}">{{ post.date | dateDisplay }}</time>
          <span class="separator">·</span>
          <span>{{ post.content | readingTime }}</span>
        </div>
        <h2 class="post-card-title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        {% if post.data.description %}
          <p class="post-card-excerpt">{{ post.data.description }}</p>
        {% endif %}
      </article>
    {% else %}
      <p>No posts with this tag.</p>
    {% endfor %}
  </section>
</div>
