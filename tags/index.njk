---
layout: base.njk
title: Tags
permalink: /tags/
---
<div class="tags-page">
  <h1>Tags</h1>
  <ul class="tags-list">
    {% for tag in collections.tagList %}
      <li>
        <a href="/tags/{{ tag | slugify }}/" class="tag">
          {{ tag }}
          <span class="tag-count">({{ collections[tag].length }})</span>
        </a>
      </li>
    {% endfor %}
  </ul>
</div>
