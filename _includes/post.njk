---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | dateToISO }}">{{ date | dateDisplay }}</time>
      <span class="separator">·</span>
      <span>{{ content | readingTime }}</span>
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
