---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | dateToISO }}">{{ date | dateDisplay }}</time>
      <span class="separator">·</span>
      <span>{{ content | readingTime }}</span>
      {% if tags %}
        {% set filteredTags = [] %}
        {% for tag in tags %}{% if tag != "posts" %}{% set filteredTags = (filteredTags.push(tag), filteredTags) %}{% endif %}{% endfor %}
        {% if filteredTags.length %}
          <span class="separator">·</span>
          <span class="post-tags">
            {% for tag in tags %}
              {% if tag != "posts" %}
                <a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
              {% endif %}
            {% endfor %}
          </span>
        {% endif %}
      {% endif %}
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
