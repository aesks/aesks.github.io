<!doctype html>
<html lang="{{ site.language }}" data-theme="auto">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title and title != "Home" %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="author" content="{{ site.author.name }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">

  <!-- RSS -->
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed.xml">

  <!-- Fonts: Inter from Google Fonts; Georgia is a system font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" referrerpolicy="no-referrer">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- Prevent flash of wrong theme -->
  <script>
    (function () {
      const saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav class="site-nav">
        <a href="/" class="site-title">{{ site.title }}</a>
        <div class="nav-links">
          <a href="/">Posts</a>
          <a href="/toys/">Toys</a>
          <a href="/me/">Me</a>
          <a href="/tags/">Tags</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">◑</button>
        </div>
      </nav>
    </div>
  </header>

  <main class="site-main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-socials">
        {% for social in socials %}
          <a href="{{ social.link }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social.icon | replace('fa-', '') }}">
            <i class="fa-brands {{ social.icon }}"></i>
          </a>
        {% endfor %}
      </div>
      <p>© {{ site.author.name }} · <a href="/feed.xml">RSS</a></p>
    </div>
  </footer>

  <script src="/js/theme-toggle.js"></script>
  <script src="/js/footnotes.js"></script>
  <script src="/js/toc.js"></script>
</body>
</html>
